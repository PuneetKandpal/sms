# Sentry Configuration
# Your Sentry DSN (same for all environments, but you can use different projects if needed)
NEXT_PUBLIC_SENTRY_DSN=https://f9d89ed574692c80288ed3a0ef2a18e2@o935625.ingest.us.sentry.io/4510242216083456

# Environment Configuration
# Explicitly set the Sentry environment (overrides automatic detection)
# Options: development, staging, production
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Application Configuration
# Version for release tracking
NEXT_PUBLIC_APP_VERSION=1.0.0

# Build timestamp (automatically set during build)
NEXT_PUBLIC_BUILD_TIME=2024-01-01T00:00:00.000Z

# API Configuration
# Backend URL for different environments
NEXT_PUBLIC_API_BASE_URL=https://jbibackend-dev.up.railway.app

# Deployment Platform Variables (automatically set by platforms)
# Vercel
NEXT_PUBLIC_VERCEL_ENV=development
NEXT_PUBLIC_VERCEL_URL=your-app.vercel.app

# Railway
RAILWAY_ENVIRONMENT=development

# Optional: Sentry Configuration Overrides
# Set to 'true' to capture all API requests as Sentry events (expensive, use in development only)
SENTRY_CAPTURE_ALL_REQUESTS=false

# Set to 'true' to capture successful API responses as Sentry events (expensive, use in development only)
SENTRY_CAPTURE_SUCCESS=false
